pipeline {
  agent any
  tools {
    maven 'maven'  // <-- Change to lowercase 'maven' to match your config
  }
  stages {
    stage('Clone') {
        steps {
            git branch: 'main',
                url: 'https://github.com/Virajsawant06/conquest_microservice.git'
        }
    }
    stage('Build') {
      steps {
        bat 'mvn clean compile'
      }
    }
    stage('Test') {
      steps {
        bat 'mvn test'
      }
    }
    stage('Package') {
      steps {
        bat 'mvn package'
      }
    }
  }
}